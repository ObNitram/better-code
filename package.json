{
  "name": "obnicode",
  "displayName": "ObniCode",
  "description": "Execute YAML-defined context actions and document formatters.",
  "version": "0.1.0",
  "publisher": "local",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:obnicode.run"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "obnicode.run",
        "title": "Choose Action...",
        "category": "Context Actions"
      }
    ],
    "submenus": [
      {
        "id": "obnicode.functionsMenu",
        "label": "Context Actions"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "submenu": "obnicode.functionsMenu",
          "group": "navigation@90"
        }
      ],
      "obnicode.functionsMenu": [
        {
          "command": "obnicode.run",
          "group": "navigation@1"
        }
      ]
    },
    "yamlValidation": [
      {
        "fileMatch": ".vscode/functions.yaml",
        "url": "./schemas/functions.schema.json"
      },
      {
        "fileMatch": "**/.vscode/functions.yaml",
        "url": "./schemas/functions.schema.json"
      },
      {
        "fileMatch": ".vscode/formatters.yaml",
        "url": "./schemas/formatters.schema.json"
      },
      {
        "fileMatch": "**/.vscode/formatters.yaml",
        "url": "./schemas/formatters.schema.json"
      }
    ],
    "configuration": {
      "title": "ObniCode",
      "properties": {
        "obnicode.functionsConfigFile": {
          "type": "string",
          "default": ".vscode/functions.yaml",
          "description": "Workspace-relative YAML configuration file containing Explorer context shell functions."
        },
        "obnicode.formattersConfigFile": {
          "type": "string",
          "default": ".vscode/formatters.yaml",
          "description": "Workspace-relative YAML configuration file containing document formatter commands."
        },
        "obnicode.systemStatus.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show CPU, memory, and storage usage in the VS Code status bar."
        },
        "obnicode.systemStatus.updateIntervalMs": {
          "type": "number",
          "default": 3000,
          "minimum": 1000,
          "description": "Refresh interval in milliseconds for the system status bar item."
        },
        "obnicode.systemStatus.diskPath": {
          "type": "string",
          "default": "",
          "description": "Path used to determine storage usage. Defaults to the first workspace folder, or the user home directory when no workspace is open."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "tsc --noEmit -p ./",
    "validate:json": "node -e \"const fs=require('fs'); for (const file of ['package.json','package-lock.json','schemas/functions.schema.json','schemas/formatters.schema.json']) JSON.parse(fs.readFileSync(file,'utf8'));\"",
    "check": "npm run lint && npm run validate:json",
    "build:vsix": "npm run check && npm run compile && vsce package",
    "vscode:prepublish": "npm run compile"
  },
  "dependencies": {
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.9.2",
    "typescript": "^5.4.5"
  }
}
